APP_ENV=production

# Database (Hostinger)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASS=your_db_password
DB_AUTO_CREATE=0

# Optional one-time default admin seed (plain-text login in current app)
# Set both values only for first run, then remove them.
SEED_ADMIN_USER=
SEED_ADMIN_PASS=

# Fallback super admin (used only when no super_admin exists)
SUPER_ADMIN_USER=
SUPER_ADMIN_PASS=

# OpenAI (only for image processing feature)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_VISION_MODEL=gpt-4o
